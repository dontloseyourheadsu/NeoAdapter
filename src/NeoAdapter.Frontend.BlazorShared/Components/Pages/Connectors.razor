    private async Task ToggleGuestPermissionAsync(IntegrationJobGuestDto guest, string permissionType, object? checkedValue)
    {
        if (_selectedJob == null || checkedValue is not bool isChecked) return;
        ClearBanners();
        
        bool canRead = permissionType == "read" ? isChecked : guest.CanRead;
        bool canEdit = permissionType == "edit" ? isChecked : guest.CanEdit;
        bool canCreateConnectors = permissionType == "create_connectors" ? isChecked : guest.CanCreateConnectors;

        try
        {
            var success = await JobsApiClient.UpdateGuestPermissionsAsync(
                _selectedJob.Id, 
                guest.UserId, 
                new UpdateGuestPermissionsRequest(canRead, canEdit, canCreateConnectors), 
                CancellationToken.None);
            if (success)
            {
                _guests = await JobsApiClient.GetGuestsAsync(_selectedJob.Id, CancellationToken.None);
            }
            else
            {
                _errorMessage = "Failed to update guest permissions.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error updating guest permissions: {ex.Message}";
        }
    }

    private async Task SaveJobAsync()
    {
        if (string.IsNullOrWhiteSpace(_jobName))
        {
            _errorMessage = "Job name is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_jobSourceId) || string.IsNullOrWhiteSpace(_jobDestinationId))
        {
            _errorMessage = "Both source and destination connectors must be specified.";
            return;
        }

        ClearBanners();
        _isBusy = true;
        try
        {
            var src = _connectors.FirstOrDefault(c => c.Id == Guid.Parse(_jobSourceId));
            var dest = _connectors.FirstOrDefault(c => c.Id == Guid.Parse(_jobDestinationId));

            if (src == null || dest == null)
            {
                _errorMessage = "Source or destination connector could not be found.";
                return;
            }

            var step = new CreateIntegrationJobStepRequest(
                0,
                src.Type,
                src.Sql != null ? new SqlConnectorSettingsInputDto(src.Sql.Host, src.Sql.Port, src.Sql.Database, src.Sql.Username, "", src.Sql.TrustServerCertificate, src.Sql.ConfigJson) : null,
                src.Csv,
                src.Excel,
                src.Path,
                src.Sftp != null ? new SftpConnectorSettingsInputDto(src.Sftp.Host, src.Sftp.Port, src.Sftp.Username, "", src.Sftp.RemotePath) : null,
                dest.Type,
                dest.Sql != null ? new SqlConnectorSettingsInputDto(dest.Sql.Host, dest.Sql.Port, dest.Sql.Database, dest.Sql.Username, "", dest.Sql.TrustServerCertificate, dest.Sql.ConfigJson) : null,
                dest.Csv,
                dest.Excel,
                dest.Path,
                dest.Sftp != null ? new SftpConnectorSettingsInputDto(dest.Sftp.Host, dest.Sftp.Port, dest.Sftp.Username, "", dest.Sftp.RemotePath) : null
            );

            var req = new CreateIntegrationJobRequest(
                _jobName,
                new[] { step },
                _jobEnabled,
                _jobCron,
                OwnerUserId: null,
                OwnerGroupId: null,
                OwnerOrganizationId: null,
                GroupIds: _selectedGroupIds,
                Password: !string.IsNullOrEmpty(_jobPassword) ? _jobPassword : null
            );

            var result = await JobsApiClient.CreateAsync(req, CancellationToken.None);
            if (result != null)
            {
                _successMessage = $"Job '{result.Name}' created successfully.";
                _isEditingJob = false;
                await LoadListsAsync();
                await SelectJob(_jobs.First(j => j.Id == result.Id));
            }
            else
            {
                _errorMessage = "Failed to create integration job.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Job save error: {ex.Message}";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void ToggleGroupSelection(Guid groupId, object? checkedValue)
    {
        bool isChecked = checkedValue is bool val && val;
        if (isChecked)
        {
            if (!_selectedGroupIds.Contains(groupId))
            {
                _selectedGroupIds.Add(groupId);
            }
        }
        else
        {
            _selectedGroupIds.Remove(groupId);
        }
    }

