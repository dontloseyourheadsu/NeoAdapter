    private void UpdateOutlookConfigJson()
    {
        var configObj = new Dictionary<string, string>();
        if (!string.IsNullOrWhiteSpace(_outlookColSubject)) configObj["subjectColumn"] = _outlookColSubject;
        if (!string.IsNullOrWhiteSpace(_outlookColBody)) configObj["bodyColumn"] = _outlookColBody;
        if (!string.IsNullOrWhiteSpace(_outlookColStart)) configObj["startColumn"] = _outlookColStart;
        if (!string.IsNullOrWhiteSpace(_outlookColEnd)) configObj["endColumn"] = _outlookColEnd;
        if (!string.IsNullOrWhiteSpace(_outlookColLocation)) configObj["locationColumn"] = _outlookColLocation;
        if (!string.IsNullOrWhiteSpace(_outlookColIsAllDay)) configObj["isAllDayColumn"] = _outlookColIsAllDay;
        if (!string.IsNullOrWhiteSpace(_outlookColRecType)) configObj["recurrenceTypeColumn"] = _outlookColRecType;
        if (!string.IsNullOrWhiteSpace(_outlookColRecInterval)) configObj["recurrenceIntervalColumn"] = _outlookColRecInterval;
        if (!string.IsNullOrWhiteSpace(_outlookColRecDays)) configObj["recurrenceDaysOfWeekColumn"] = _outlookColRecDays;
        if (!string.IsNullOrWhiteSpace(_outlookColRecRange)) configObj["recurrenceRangeTypeColumn"] = _outlookColRecRange;
        if (!string.IsNullOrWhiteSpace(_outlookColRecEnd)) configObj["recurrenceEndDateColumn"] = _outlookColRecEnd;
        if (!string.IsNullOrWhiteSpace(_outlookColRecOcc)) configObj["recurrenceOccurrencesColumn"] = _outlookColRecOcc;

        _outlookConfigJson = JsonSerializer.Serialize(configObj);
    }

    private void LoadOutlookConfig(string? json)
    {
        _outlookColSubject = "Subject";
        _outlookColBody = "Body";
        _outlookColStart = "Start";
        _outlookColEnd = "End";
        _outlookColLocation = "Location";
        _outlookColIsAllDay = "IsAllDay";
        _outlookColRecType = "RecurrenceType";
        _outlookColRecInterval = "RecurrenceInterval";
        _outlookColRecDays = "RecurrenceDaysOfWeek";
        _outlookColRecRange = "RecurrenceRangeType";
        _outlookColRecEnd = "RecurrenceEndDate";
        _outlookColRecOcc = "RecurrenceOccurrences";

        if (!string.IsNullOrEmpty(json))
        {
            try
            {
                using var doc = JsonDocument.Parse(json);
                var root = doc.RootElement;
                JsonElement p;
                if (root.TryGetProperty("subjectColumn", out p)) _outlookColSubject = p.GetString() ?? _outlookColSubject;
                if (root.TryGetProperty("bodyColumn", out p)) _outlookColBody = p.GetString() ?? _outlookColBody;
                if (root.TryGetProperty("startColumn", out p)) _outlookColStart = p.GetString() ?? _outlookColStart;
                if (root.TryGetProperty("endColumn", out p)) _outlookColEnd = p.GetString() ?? _outlookColEnd;
                if (root.TryGetProperty("locationColumn", out p)) _outlookColLocation = p.GetString() ?? _outlookColLocation;
                if (root.TryGetProperty("isAllDayColumn", out p)) _outlookColIsAllDay = p.GetString() ?? _outlookColIsAllDay;
                if (root.TryGetProperty("recurrenceTypeColumn", out p)) _outlookColRecType = p.GetString() ?? _outlookColRecType;
                if (root.TryGetProperty("recurrenceIntervalColumn", out p)) _outlookColRecInterval = p.GetString() ?? _outlookColRecInterval;
                if (root.TryGetProperty("recurrenceDaysOfWeekColumn", out p)) _outlookColRecDays = p.GetString() ?? _outlookColRecDays;
                if (root.TryGetProperty("recurrenceRangeTypeColumn", out p)) _outlookColRecRange = p.GetString() ?? _outlookColRecRange;
                if (root.TryGetProperty("recurrenceEndDateColumn", out p)) _outlookColRecEnd = p.GetString() ?? _outlookColRecEnd;
                if (root.TryGetProperty("recurrenceOccurrencesColumn", out p)) _outlookColRecOcc = p.GetString() ?? _outlookColRecOcc;
            }
            catch {}
        }
    }

