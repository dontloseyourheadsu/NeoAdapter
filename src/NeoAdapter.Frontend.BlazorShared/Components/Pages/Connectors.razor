@using System.Threading
@using NeoAdapter.Contracts.Connectors
@using NeoAdapter.Contracts.IntegrationJobs
@using NeoAdapter.Frontend.BlazorShared.Services
@using System.Text.Json
@inject AppState AppState
@inject ConnectorApiClient ConnectorApiClient
@inject IntegrationJobsApiClient JobsApiClient
@inject OrgAdminApiClient OrgAdminApiClient

<div style="padding: 28px 32px; display: flex; flex-direction: column; gap: 24px;">
    
    <!-- Title / Breadcrumb -->
    <div>
        <div style="font-family: var(--font-mono); font-size: 11px; color: var(--violet-300); letter-spacing: 0.1em; text-transform: uppercase;">Nexus Workspace</div>
        <h1 style="font-size: 28px; font-weight: 800; margin: 4px 0 0; background: linear-gradient(135deg, white, var(--text-secondary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Connectors &amp; Jobs</h1>
    </div>

    <!-- Navigation Tabs -->
    <div style="display: flex; gap: 12px; border-bottom: 1px solid var(--border); padding-bottom: 12px;">
        <button class="btn-ghost @(_activeTab == "connectors" ? "active" : "")" style="padding: 8px 16px; font-family: var(--font-display); font-size: 14px; font-weight: 600;" @onclick='() => _activeTab = "connectors"'>
            ◫ Connectors
        </button>
        <button class="btn-ghost @(_activeTab == "jobs" ? "active" : "")" style="padding: 8px 16px; font-family: var(--font-display); font-size: 14px; font-weight: 600;" @onclick='() => _activeTab = "jobs"'>
            ⬡ Integration Jobs
        </button>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert-danger">@_errorMessage</div>
    }
    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="alert-success">@_successMessage</div>
    }

    <!-- Tab Contents -->
    <div class="content-grid">
        
        <!-- Left Panel: Lists -->
        <div class="panel">
            @if (_activeTab == "connectors")
            {
                <div class="panel-header">
                    <div class="panel-title">CONNECTOR LIST</div>
                    <button class="btn-primary" @onclick="PrepareNewConnector">
                        <span>+</span> New Connector
                    </button>
                </div>
                <div class="job-list">
                    @if (_connectors.Count == 0)
                    {
                        <div style="padding: 32px; text-align: center; color: var(--text-muted); font-size: 13px;">
                            No connectors configured. Add one to get started.
                        </div>
                    }
                    else
                    {
                        @foreach (var connector in _connectors)
                        {
                            var isSelected = _selectedConnector?.Id == connector.Id;
                            var typeClass = connector.Type == ConnectorType.SqlServer ? "blue" : connector.Type == ConnectorType.Postgres ? "violet" : connector.Type == ConnectorType.SharePoint ? "orange" : connector.Type == ConnectorType.OutlookCalendar ? "blue" : "green";
                            <div class="job-item @(isSelected ? "active" : "")" @onclick="() => SelectConnector(connector)" style="cursor: pointer;">
                                <div class="job-item-icon @typeClass">
                                    @(connector.Type == ConnectorType.SqlServer ? "🛢" : connector.Type == ConnectorType.Postgres ? "🐘" : connector.Type == ConnectorType.SharePoint ? "S" : connector.Type == ConnectorType.OutlookCalendar ? "📅" : "📄")
                                </div>
                                <div class="job-item-info">
                                    <div class="job-item-name">@connector.Name</div>
                                    <div class="job-item-meta">@connector.Type.ToString() · Created @connector.CreatedAtUtc.ToString("yyyy-MM-dd")</div>
                                </div>
                                <span class="status-pill idle">CONNECTED</span>
                            </div>
                        }
                    }
                </div>
            }
            else
            {
                <div class="panel-header">
                    <div class="panel-title">INTEGRATION JOBS</div>
                    <button class="btn-primary" @onclick="PrepareNewJob">
                        <span>+</span> Create Job
                    </button>
                </div>
                <div class="job-list">
                    @if (_jobs.Count == 0)
                    {
                        <div style="padding: 32px; text-align: center; color: var(--text-muted); font-size: 13px;">
                            No integration jobs configured. Create one to begin migrating data.
                        </div>
                    }
                    else
                    {
                        @foreach (var job in _jobs)
                        {
                            var isSelected = _selectedJob?.Id == job.Id;
                            <div class="job-item @(isSelected ? "active" : "")" @onclick="() => SelectJob(job)" style="cursor: pointer;">
                                <div class="job-item-icon violet">⬡</div>
                                <div class="job-item-info">
                                    <div class="job-item-name">
                                        @job.Name
                                        @if (job.IsPasswordProtected)
                                        {
                                            <span style="margin-left: 6px; font-size: 11px;" title="@(job.IsUnlocked ? "Unlocked" : "Locked")">
                                                @(job.IsUnlocked ? "🔓" : "🔒")
                                            </span>
                                        }
                                    </div>
                                    <div class="job-item-meta">CRON: @job.CronExpression | Enabled: @job.IsEnabled</div>
                                </div>
                                <div style="display: flex; gap: 8px;" @onclick:stopPropagation="true">
                                    @if (!job.IsPasswordProtected || job.IsUnlocked)
                                    {
                                        <button class="btn-ghost" style="padding: 2px 8px; font-size: 10px;" @onclick="() => RunJobAsync(job)">Run Now</button>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            }
        </div>

        <!-- Right Panel: Editor / Details -->
        <div class="panel" style="padding: 24px;">
            @if (_activeTab == "connectors")
            {
                if (_isEditingConnector || _selectedConnector != null)
                {
                    <h3 style="margin-top: 0; margin-bottom: 20px; font-size: 16px; font-weight: 700; color: var(--violet-300);">
                        @(_isEditingConnector ? "CREATE NEW CONNECTOR" : "CONNECTOR DETAILS")
                    </h3>

                    <div class="form-group">
                        <label class="form-label">Connector Name</label>
                        <input type="text" class="form-input" @bind="_connName" readonly="@(!_isEditingConnector)" placeholder="e.g. Production SqlServer" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Type</label>
                        @if (_isEditingConnector)
                        {
                            <select class="form-input" @bind="_connType">
                                <option value="@ConnectorType.SqlServer">SQL Server (SqlServer)</option>
                                <option value="@ConnectorType.Postgres">PostgreSQL (Postgres)</option>
                                <option value="@ConnectorType.Csv">CSV File (Csv)</option>
                                <option value="@ConnectorType.Path">Path (Local Directory/File)</option>
                                <option value="@ConnectorType.Sftp">SFTP Server</option>
                                <option value="@ConnectorType.SharePoint">SharePoint List (SharePoint)</option>
                                <option value="@ConnectorType.OutlookCalendar">Outlook Calendar (Outlook)</option>
                            </select>
                        }
                        else
                        {
                            <input type="text" class="form-input" value="@_selectedConnector?.Type.ToString()" readonly />
                        }
                    </div>

                    @if (_connType == ConnectorType.SqlServer || _connType == ConnectorType.Postgres)
                    {
                        <div class="form-group">
                            <label class="form-label">Host</label>
                            <input type="text" class="form-input" @bind="_sqlHost" readonly="@(!_isEditingConnector)" placeholder="localhost or domain" />
                        </div>
                        <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 12px;">
                            <div class="form-group">
                                <label class="form-label">Port</label>
                                <input type="number" class="form-input" @bind="_sqlPort" readonly="@(!_isEditingConnector)" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Database Name</label>
                                <input type="text" class="form-input" @bind="_sqlDatabase" readonly="@(!_isEditingConnector)" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Username</label>
                            <input type="text" class="form-input" @bind="_sqlUsername" readonly="@(!_isEditingConnector)" />
                        </div>
                        @if (_isEditingConnector)
                        {
                            <div class="form-group">
                                <label class="form-label">Password</label>
                                <input type="password" class="form-input" @bind="_sqlPassword" />
                            </div>
                        }
                        <div class="form-group">
                            <label class="form-checkbox">
                                <input type="checkbox" @bind="_sqlTrustCert" disabled="@(!_isEditingConnector)" />
                                Trust Server Certificate
                            </label>
                        </div>
                    }
                    else if (_connType == ConnectorType.Csv)
                    {
                        <div class="form-group">
                            <label class="form-label">File Path</label>
                            <input type="text" class="form-input" @bind="_csvPath" readonly="@(!_isEditingConnector)" placeholder="/path/to/file.csv" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Delimiter</label>
                            <input type="text" class="form-input" @bind="_csvDelimiter" readonly="@(!_isEditingConnector)" />
                        </div>
                    }
                    else if (_connType == ConnectorType.Path)
                    {
                        <div class="form-group">
                            <label class="form-label">Local Path</label>
                            <input type="text" class="form-input" @bind="_localPath" readonly="@(!_isEditingConnector)" placeholder="e.g. C:\temp\files" />
                        </div>
                    }
                    else if (_connType == ConnectorType.Sftp)
                    {
                        <div class="form-group">
                            <label class="form-label">SFTP Host</label>
                            <input type="text" class="form-input" @bind="_sftpHost" readonly="@(!_isEditingConnector)" placeholder="e.g. sftp.example.com" />
                        </div>
                        <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 12px;">
                            <div class="form-group">
                                <label class="form-label">SFTP Port</label>
                                <input type="number" class="form-input" @bind="_sftpPort" readonly="@(!_isEditingConnector)" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">SFTP Username</label>
                                <input type="text" class="form-input" @bind="_sftpUsername" readonly="@(!_isEditingConnector)" />
                            </div>
                        </div>
                        @if (_isEditingConnector)
                        {
                            <div class="form-group">
                                <label class="form-label">SFTP Password</label>
                                <input type="password" class="form-input" @bind="_sftpPassword" />
                            </div>
                        }
                        <div class="form-group">
                            <label class="form-label">SFTP Remote Path</label>
                            <input type="text" class="form-input" @bind="_sftpRemotePath" readonly="@(!_isEditingConnector)" placeholder="e.g. /upload" />
                        </div>
                    }
                    else if (_connType == ConnectorType.SharePoint)
                    {
                        <div class="form-group">
                            <label class="form-label">Site URL</label>
                            <input type="text" class="form-input" @bind="_sharepointSiteUrl" readonly="@(!_isEditingConnector)" placeholder="https://tenant.sharepoint.com/sites/yoursite" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">List Name</label>
                            <div style="display: flex; gap: 8px;">
                                @if (_isEditingConnector)
                                {
                                    <input type="text" class="form-input" @bind="_sharepointListName" placeholder="Type list name or load lists" style="flex: 1;" />
                                    <button type="button" class="btn-secondary" @onclick="LoadSharePointListsAsync" disabled="@_isBusy">Load Lists</button>
                                }
                                else
                                {
                                    <input type="text" class="form-input" value="@_sharepointListName" readonly />
                                }
                            </div>
                        </div>
                        @if (_sharepointLists.Count > 0 && _isEditingConnector)
                        {
                            <div class="form-group">
                                <label class="form-label">Select List</label>
                                <select class="form-input" @onchange="OnSharePointListSelected">
                                    <option value="">-- Choose List --</option>
                                    @foreach (var list in _sharepointLists)
                                    {
                                        <option value="@list">@list</option>
                                    }
                                </select>
                            </div>
                        }
                        
                        @if (_sharepointFields.Count > 0)
                        {
                            <div class="form-group">
                                <label class="form-label">Available Fields</label>
                                <div style="max-height: 200px; overflow-y: auto; background: var(--dark-200); padding: 8px; border-radius: 4px; font-size: 13px;">
                                    @foreach (var f in _sharepointFields)
                                    {
                                        <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--dark-300); padding: 4px 0;">
                                            <span>@f.Title</span>
                                            <span style="color: var(--text-muted); font-family: monospace;">@f.TypeAsString</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else if (_connType == ConnectorType.OutlookCalendar)
                    {
                        <div class="form-group">
                            <label class="form-label">Calendar Name</label>
                            <div style="display: flex; gap: 8px;">
                                @if (_isEditingConnector)
                                {
                                    <input type="text" class="form-input" @bind="_outlookCalendarName" placeholder="Calendar Name (e.g. Calendar)" style="flex: 1;" />
                                    <button type="button" class="btn-secondary" @onclick="LoadOutlookCalendarsAsync" disabled="@_isBusy">Load Calendars</button>
                                }
                                else
                                {
                                    <input type="text" class="form-input" value="@_outlookCalendarName" readonly />
                                }
                            </div>
                        </div>
                        @if (_outlookCalendars.Count > 0 && _isEditingConnector)
                        {
                            <div class="form-group">
                                <label class="form-label">Select Calendar</label>
                                <select class="form-input" @onchange="OnOutlookCalendarSelected">
                                    <option value="">-- Choose Calendar --</option>
                                    @foreach (var cal in _outlookCalendars)
                                    {
                                        <option value="@cal">@cal</option>
                                    }
                                </select>
                            </div>
                        }

                        <h4 style="margin-top: 20px; border-bottom: 1px solid var(--dark-300); padding-bottom: 8px;">Field Column Mapping</h4>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 10px;">
                            <div class="form-group">
                                <label class="form-label">Subject Column</label>
                                <input type="text" class="form-input" @bind="_outlookColSubject" readonly="@(!_isEditingConnector)" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Body/Description Column</label>
                                <input type="text" class="form-input" @bind="_outlookColBody" readonly="@(!_isEditingConnector)" />
                            </div>
                        </div>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                            <div class="form-group">
                                <label class="form-label">Start Date/Time Column</label>
                                <input type="text" class="form-input" @bind="_outlookColStart" readonly="@(!_isEditingConnector)" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">End Date/Time Column</label>
                                <input type="text" class="form-input" @bind="_outlookColEnd" readonly="@(!_isEditingConnector)" />
                            </div>
                        </div>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                            <div class="form-group">
                                <label class="form-label">Location Column</label>
                                <input type="text" class="form-input" @bind="_outlookColLocation" readonly="@(!_isEditingConnector)" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Is All Day Column</label>
                                <input type="text" class="form-input" @bind="_outlookColIsAllDay" readonly="@(!_isEditingConnector)" />
                            </div>
                        </div>

                        <h4 style="margin-top: 20px; border-bottom: 1px solid var(--dark-300); padding-bottom: 8px;">Recurrence Mapping (Optional)</h4>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 10px;">
                            <div class="form-group">
                                <label class="form-label">Recurrence Type Column</label>
                                <input type="text" class="form-input" @bind="_outlookColRecType" readonly="@(!_isEditingConnector)" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Recurrence Interval Column</label>
                                <input type="text" class="form-input" @bind="_outlookColRecInterval" readonly="@(!_isEditingConnector)" />
                            </div>
                        </div>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                            <div class="form-group">
                                <label class="form-label">Recurrence Days Column</label>
                                <input type="text" class="form-input" @bind="_outlookColRecDays" readonly="@(!_isEditingConnector)" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Range Type Column</label>
                                <input type="text" class="form-input" @bind="_outlookColRecRange" readonly="@(!_isEditingConnector)" />
                            </div>
                        </div>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                            <div class="form-group">
                                <label class="form-label">Recurrence End Date Column</label>
                                <input type="text" class="form-input" @bind="_outlookColRecEnd" readonly="@(!_isEditingConnector)" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Occurrences Column</label>
                                <input type="text" class="form-input" @bind="_outlookColRecOcc" readonly="@(!_isEditingConnector)" />
                            </div>
                        </div>
                    }

                    @if (_isEditingConnector)
                    {
                        <div style="display: flex; gap: 12px; margin-top: 24px;">
                            <button class="btn-ghost" @onclick="TestConnectionAsync" disabled="@_isBusy">Test Connection</button>
                            <button class="btn-primary" @onclick="SaveConnectorAsync" disabled="@_isBusy" style="margin-left: auto;">Save Connector</button>
                        </div>
                    }
                    else
                    {
                        <div style="margin-top: 24px; color: var(--text-muted); font-size: 11.5px; font-family: var(--font-mono);">
                            Connector ID: @_selectedConnector?.Id
                        </div>
                    }
                }
                else
                {
                    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; min-height: 250px; color: var(--text-muted);">
                        <span>◫</span>
                        <div style="font-size: 13px; margin-top: 8px;">Select a connector from the list or create a new one.</div>
                    </div>
                }
            }
            else
            {
                if (_isEditingJob || _selectedJob != null)
                {
                    <h3 style="margin-top: 0; margin-bottom: 20px; font-size: 16px; font-weight: 700; color: var(--violet-300);">
                        @(_isEditingJob ? "CREATE INTEGRATION JOB" : "JOB RUN DETAILS & HISTORY")
                    </h3>

                    <div class="form-group">
                        <label class="form-label">Job Name</label>
                        <input type="text" class="form-input" @bind="_jobName" readonly="@(!_isEditingJob)" placeholder="e.g. Sales Sync Postgres to Sql" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Cron Schedule</label>
                        <input type="text" class="form-input" @bind="_jobCron" readonly="@(!_isEditingJob)" placeholder="e.g. */15 * * * *" />
                    </div>

                    <div class="form-group">
                        <label class="form-checkbox">
                            <input type="checkbox" @bind="_jobEnabled" disabled="@(!_isEditingJob)" />
                            IsEnabled
                        </label>
                    </div>

                    @if (_isEditingJob)
                    {
                        <div class="form-group">
                            <label class="form-label">Job Password (Optional)</label>
                            <input type="password" class="form-input" @bind="_jobPassword" placeholder="Enter password to restrict access" />
                        </div>
                    }

                    @if (_isEditingJob)
                    {
                        <div class="form-group">
                            <label class="form-label">Source Connector</label>
                            <select class="form-input" @bind="_jobSourceId">
                                <option value="">-- Select Source --</option>
                                @foreach (var c in _connectors)
                                {
                                    <option value="@c.Id">@c.Name (@c.Type)</option>
                                }
                            </select>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Destination Connector</label>
                            <select class="form-input" @bind="_jobDestinationId">
                                <option value="">-- Select Destination --</option>
                                @foreach (var c in _connectors)
                                {
                                    <option value="@c.Id">@c.Name (@c.Type)</option>
                                }
                            </select>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Share with Groups</label>
                            <div style="display: flex; flex-direction: column; gap: 8px; max-height: 120px; overflow-y: auto; padding: 10px; border: 1px solid var(--border); border-radius: var(--radius-sm); background: var(--bg-surface);">
                                @if (_orgGroups == null || _orgGroups.Count == 0)
                                {
                                    <div style="color: var(--text-muted); font-size: 12px;">No organization groups available.</div>
                                }
                                else
                                {
                                    @foreach (var group in _orgGroups)
                                    {
                                        var gid = group.Id;
                                        <label style="display: flex; align-items: center; gap: 8px; font-size: 13px; cursor: pointer; color: var(--text-secondary);">
                                            <input type="checkbox" checked="@_selectedGroupIds.Contains(gid)" @onchange="@(e => ToggleGroupSelection(gid, e.Value))" />
                                            @group.Name
                                        </label>
                                    }
                                }
                            </div>
                        </div>

                        <div style="display: flex; gap: 12px; margin-top: 24px;">
                            <button class="btn-ghost" @onclick="() => _isEditingJob = false">Cancel</button>
                            <button class="btn-primary" @onclick="SaveJobAsync" disabled="@_isBusy" style="margin-left: auto;">Save Workflow</button>
                        </div>
                    }
                    else if (_selectedJob.IsPasswordProtected && !_selectedJob.IsUnlocked)
                    {
                        <!-- Password Locked Screen -->
                        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px 20px; background: rgba(255, 255, 255, 0.02); border: 1px solid var(--border); border-radius: var(--radius-md); text-align: center; margin-top: 20px;">
                            <span style="font-size: 36px; margin-bottom: 16px;">🔒</span>
                            <h4 style="margin: 0 0 8px 0; font-size: 16px; font-weight: 600; color: var(--violet-300);">This Job is Password Protected</h4>
                            <p style="margin: 0 0 20px 0; font-size: 13px; color: var(--text-muted); max-width: 320px;">
                                You can see this job in the list, but you need to enter the password to view its contents, steps, logs, and run history.
                            </p>
                            <div class="form-group" style="width: 100%; max-width: 280px; margin-bottom: 16px;">
                                <input type="password" class="form-input" @bind="_unlockPassword" placeholder="Enter password..." @onkeyup="HandleUnlockKeyup" style="text-align: center;" />
                            </div>
                            <button class="btn-primary" style="width: 100%; max-width: 280px;" @onclick="UnlockJobAsync" disabled="@_isBusy">Unlock Workflow</button>
                        </div>
                    }
                    else
                    {
                        <!-- Sub Tabs -->
                        <div style="display: flex; gap: 8px; border-bottom: 1px solid var(--border); padding-bottom: 8px; margin-bottom: 16px;">
                            <button class="btn-ghost @(_jobSubTab == "details" ? "active" : "")" style="padding: 4px 10px; font-size: 12px; font-weight: 600;" @onclick='() => _jobSubTab = "details"'>
                                ℹ Details
                            </button>
                            <button class="btn-ghost @(_jobSubTab == "access" ? "active" : "")" style="padding: 4px 10px; font-size: 12px; font-weight: 600;" @onclick='() => _jobSubTab = "access"'>
                                🔒 Access Control
                            </button>
                        </div>

                        @if (_jobSubTab == "details")
                        {
                            <!-- Shared Groups List -->
                            <div style="margin-top: 16px; margin-bottom: 16px;">
                                <div class="section-title" style="margin-bottom: 6px;">Shared Groups</div>
                                <div style="display: flex; flex-wrap: wrap; gap: 6px;">
                                    @if (_selectedJob!.GroupIds == null || _selectedJob!.GroupIds.Count == 0)
                                    {
                                        <span class="status-pill idle" style="font-size: 10px;">Organization-Wide / Not Shared</span>
                                    }
                                    else
                                    {
                                        @foreach (var gid in _selectedJob!.GroupIds)
                                        {
                                            var groupName = _orgGroups.FirstOrDefault(g => g.Id == gid)?.Name ?? "Unknown Group";
                                            <span class="status-pill running" style="font-size: 10px; background: var(--blue-dim); color: var(--blue);">@groupName</span>
                                        }
                                    }
                                </div>
                            </div>

                            <!-- Runs History -->
                            <div style="margin-top: 20px;">
                                <div class="section-title" style="margin-bottom: 8px;">Run Execution History</div>
                                <div style="max-height: 200px; overflow-y: auto; border: 1px solid var(--border); border-radius: var(--radius-sm); background: var(--bg-surface);">
                                    @if (_runs == null || _runs.Count == 0)
                                    {
                                        <div style="padding: 16px; text-align: center; color: var(--text-muted); font-size: 12px;">No runs recorded.</div>
                                    }
                                    else
                                    {
                                        @foreach (var run in _runs)
                                        {
                                            var pillClass = run.Status == "Success" ? "status-pill running" : "status-pill failed";
                                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 8px 12px; border-bottom: 1px solid var(--border);">
                                                <div style="font-family: var(--font-mono); font-size: 11px;">
                                                    <div>@run.StartedAtUtc.ToLocalTime().ToString("g")</div>
                                                    <div style="color: var(--text-muted); font-size: 10px;">Duration: @(run.FinishedAtUtc.HasValue ? (run.FinishedAtUtc.Value - run.StartedAtUtc).TotalSeconds.ToString("0.0") + "s" : "-")</div>
                                                </div>
                                                <span class="@pillClass">@(run.Status ?? "Running")</span>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>

                            <div style="display: flex; gap: 12px; margin-top: 24px;">
                                <button class="btn-primary" @onclick="() => RunJobAsync(_selectedJob!)" disabled="@_isBusy">Run Now</button>
                            </div>
                        }
                        else if (_jobSubTab == "access")
                        {
                            <!-- Owners List -->
                            <div style="margin-bottom: 20px;">
                                <div class="section-title" style="margin-bottom: 8px; display: flex; justify-content: space-between; align-items: center;">
                                    <span>Job Owners</span>
                                </div>
                                <div style="max-height: 150px; overflow-y: auto; border: 1px solid var(--border); border-radius: var(--radius-sm); background: var(--bg-surface); padding: 4px 0;">
                                    @if (_owners == null || _owners.Count == 0)
                                    {
                                        <div style="padding: 8px 12px; color: var(--text-muted); font-size: 12px;">No owners found.</div>
                                    }
                                    else
                                    {
                                        @foreach (var owner in _owners)
                                        {
                                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 6px 12px; border-bottom: 1px solid var(--border); font-size: 12px;">
                                                <div style="display: flex; flex-direction: column;">
                                                    <span style="font-weight: 600; color: var(--text-secondary);">@owner.Username</span>
                                                    @if (!string.IsNullOrEmpty(owner.Email))
                                                    {
                                                        <span style="color: var(--text-muted); font-size: 10px;">@owner.Email</span>
                                                    }
                                                </div>
                                                <div style="display: flex; align-items: center; gap: 8px;">
                                                    @if (owner.IsCreator)
                                                    {
                                                        <span class="status-pill running" style="font-size: 9px; padding: 1px 4px; background: var(--violet-dim); color: var(--violet-300);">Creator</span>
                                                    }
                                                    else if (CanManageAccess())
                                                    {
                                                        <button class="btn-ghost" style="padding: 2px 6px; font-size: 10px; color: var(--red); border-color: rgba(239, 68, 68, 0.2);" @onclick="() => RemoveOwnerAsync(owner.UserId)">Remove</button>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    }
                                </div>

                                @if (CanManageAccess())
                                {
                                    <!-- Add Owner Form -->
                                    <div style="display: flex; gap: 8px; margin-top: 8px;">
                                        <input type="text" class="form-input" style="flex: 1; padding: 4px 8px; font-size: 12px;" placeholder="Add owner by username..." @bind="_newOwnerUsername" />
                                        <button class="btn-primary" style="padding: 4px 12px; font-size: 12px;" @onclick="AddOwnerAsync" disabled="@_isBusy">Add</button>
                                    </div>
                                }
                            </div>

                            <!-- Guests List -->
                            <div>
                                <div class="section-title" style="margin-bottom: 8px;">Invited Guests</div>
                                <div style="max-height: 220px; overflow-y: auto; border: 1px solid var(--border); border-radius: var(--radius-sm); background: var(--bg-surface); padding: 4px 0; margin-bottom: 12px;">
                                    @if (_guests == null || _guests.Count == 0)
                                    {
                                        <div style="padding: 8px 12px; color: var(--text-muted); font-size: 12px;">No guests invited yet.</div>
                                    }
                                    else
                                    {
                                        @foreach (var guest in _guests)
                                        {
                                            <div style="padding: 8px 12px; border-bottom: 1px solid var(--border); font-size: 12px; display: flex; flex-direction: column; gap: 6px;">
                                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                                    <span style="font-weight: 600; color: var(--text-secondary);">@guest.Username</span>
                                                    @if (CanManageAccess())
                                                    {
                                                        <button class="btn-ghost" style="padding: 1px 5px; font-size: 9px; color: var(--red); border-color: rgba(239, 68, 68, 0.2);" @onclick="() => RemoveGuestAsync(guest.UserId)">Remove</button>
                                                    }
                                                </div>
                                                <!-- Permission Toggles -->
                                                <div style="display: flex; gap: 12px; font-size: 10px; color: var(--text-muted);">
                                                    <label style="display: flex; align-items: center; gap: 4px;">
                                                        <input type="checkbox" checked="@guest.CanRead" disabled="@(!CanManageAccess())" @onchange="@(e => ToggleGuestPermissionAsync(guest, "read", e.Value))" />
                                                        Read
                                                    </label>
                                                    <label style="display: flex; align-items: center; gap: 4px;">
                                                        <input type="checkbox" checked="@guest.CanEdit" disabled="@(!CanManageAccess())" @onchange="@(e => ToggleGuestPermissionAsync(guest, "edit", e.Value))" />
                                                        Edit
                                                    </label>
                                                    <label style="display: flex; align-items: center; gap: 4px;">
                                                        <input type="checkbox" checked="@guest.CanCreateConnectors" disabled="@(!CanManageAccess())" @onchange="@(e => ToggleGuestPermissionAsync(guest, "create_connectors", e.Value))" />
                                                        Connectors
                                                    </label>
                                                </div>
                                            </div>
                                        }
                                    }
                                </div>

                                @if (CanManageAccess())
                                {
                                    <!-- Invite Guest Form -->
                                    <div style="border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 10px; background: rgba(255, 255, 255, 0.02);">
                                        <div style="font-size: 11px; font-weight: 600; color: var(--text-secondary); margin-bottom: 6px;">Invite a New Guest</div>
                                        <div class="form-group" style="margin-bottom: 8px;">
                                            <input type="text" class="form-input" style="padding: 4px 8px; font-size: 12px;" placeholder="Username..." @bind="_newGuestUsername" />
                                        </div>
                                        <div style="display: flex; gap: 12px; font-size: 11px; color: var(--text-secondary); margin-bottom: 8px;">
                                            <label style="display: flex; align-items: center; gap: 4px; cursor: pointer;">
                                                <input type="checkbox" @bind="_newGuestCanRead" />
                                                Read
                                            </label>
                                            <label style="display: flex; align-items: center; gap: 4px; cursor: pointer;">
                                                <input type="checkbox" @bind="_newGuestCanEdit" />
                                                Edit
                                            </label>
                                            <label style="display: flex; align-items: center; gap: 4px; cursor: pointer;">
                                                <input type="checkbox" @bind="_newGuestCanCreateConnectors" />
                                                Connectors
                                            </label>
                                        </div>
                                        <button class="btn-primary" style="width: 100%; padding: 4px 12px; font-size: 12px;" @onclick="InviteGuestAsync" disabled="@_isBusy">Invite Guest</button>
                                    </div>
                                }
                            </div>

                            @if (IsCreator())
                            {
                                <div style="margin-top: 24px; padding-top: 20px; border-top: 1px dashed var(--border);">
                                    <div class="section-title" style="margin-bottom: 8px;">Job Password Security</div>
                                    <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 12px;">
                                        Setting or changing a password will reset all permissions (removing all invited guests and existing password unlocks). Leave empty to remove password protection.
                                    </div>
                                    <div style="display: flex; gap: 8px; align-items: center;">
                                        <input type="password" class="form-input" style="flex: 1; padding: 4px 8px; font-size: 12px;" placeholder="New password (optional)..." @bind="_changePasswordInput" />
                                        <button class="btn-primary" style="padding: 4px 12px; font-size: 12px; background: var(--amber-600); border-color: var(--amber-600);" @onclick="UpdatePasswordAsync" disabled="@_isBusy">
                                            Update Password
                                        </button>
                                    </div>
                                </div>
                            }
                        }
                    }
                }
                else
                {
                    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; min-height: 250px; color: var(--text-muted);">
                        <span>⬡</span>
                        <div style="font-size: 13px; margin-top: 8px;">Select a workflow job to execute or configure a new integration.</div>
                    </div>
                }
            }
        </div>
        
    </div>
    
</div>

@code {
    private string _activeTab = "connectors";
    private IReadOnlyList<ConnectorDto> _connectors = [];
    private IReadOnlyList<IntegrationJobDto> _jobs = [];
    private IReadOnlyList<IntegrationJobRunDto> _runs = [];
    private IReadOnlyList<NeoAdapter.Contracts.Auth.OrganizationGroupDto> _orgGroups = [];
    private List<Guid> _selectedGroupIds = new();

    private ConnectorDto? _selectedConnector;
    private IntegrationJobDto? _selectedJob;

    private IReadOnlyList<IntegrationJobOwnerDto> _owners = [];
    private IReadOnlyList<IntegrationJobGuestDto> _guests = [];
    private string _jobSubTab = "details";

    private string _newOwnerUsername = "";
    private string _newGuestUsername = "";
    private bool _newGuestCanRead = true;
    private bool _newGuestCanEdit = false;
    private bool _newGuestCanCreateConnectors = false;

    private bool _isEditingConnector = false;
    private bool _isEditingJob = false;
    private bool _isBusy = false;

    private string? _errorMessage;
    private string? _successMessage;

    // Form bindings (Connector)
    private string _connName = "";
    private ConnectorType _connType = ConnectorType.SqlServer;
    private string _sqlHost = "localhost";
    private int _sqlPort = 5432;
    private string _sqlDatabase = "";
    private string _sqlUsername = "";
    private string _sqlPassword = "";
    private bool _sqlTrustCert = true;
    private string _csvPath = "";
    private string _csvDelimiter = ",";
    
    private string _localPath = "";
    private string _sftpHost = "";
    private int _sftpPort = 22;
    private string _sftpUsername = "";
    private string _sftpPassword = "";
    private string _sftpRemotePath = "";
    private string _sharepointSiteUrl = "";
    private string _sharepointListName = "";
    private string _sharepointConfigJson = "";
    private List<string> _sharepointLists = new();
    private List<SharePointFieldDto> _sharepointFields = new();
    private string _outlookCalendarName = "";
    private string _outlookConfigJson = "";
    private List<string> _outlookCalendars = new();
    private string _outlookColSubject = "Subject";
    private string _outlookColBody = "Body";
    private string _outlookColStart = "Start";
    private string _outlookColEnd = "End";
    private string _outlookColLocation = "Location";
    private string _outlookColIsAllDay = "IsAllDay";
    private string _outlookColRecType = "RecurrenceType";
    private string _outlookColRecInterval = "RecurrenceInterval";
    private string _outlookColRecDays = "RecurrenceDaysOfWeek";
    private string _outlookColRecRange = "RecurrenceRangeType";
    private string _outlookColRecEnd = "RecurrenceEndDate";
    private string _outlookColRecOcc = "RecurrenceOccurrences";

    // Form bindings (Job)
    private string _jobName = "";
    private string _jobCron = "0 * * * *";
    private bool _jobEnabled = true;
    private string _jobSourceId = "";
    private string _jobDestinationId = "";
    private string _jobPassword = "";
    private string _unlockPassword = "";
    private string _changePasswordInput = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadListsAsync();
    }

    private async Task LoadListsAsync()
    {
        _errorMessage = null;
        try
        {
            _connectors = await ConnectorApiClient.GetAllAsync(CancellationToken.None);
            _jobs = await JobsApiClient.GetAllAsync(CancellationToken.None);
            _orgGroups = await OrgAdminApiClient.GetGroupsAsync(CancellationToken.None);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load configuration: {ex.Message}";
        }
    }

    private void PrepareNewConnector()
    {
        _selectedConnector = null;
        _connName = "";
        _connType = ConnectorType.Postgres;
        _sqlHost = "127.0.0.1";
        _sqlPort = 5432;
        _sqlDatabase = "neoadapter_dev";
        _sqlUsername = "postgres";
        _sqlPassword = "";
        _sqlTrustCert = true;
        _csvPath = "";
        _csvDelimiter = ",";
        _localPath = "";
        _sftpHost = "";
        _sftpPort = 22;
        _sftpUsername = "";
        _sftpPassword = "";
        _sftpRemotePath = "";
        _sharepointSiteUrl = "";
        _sharepointListName = "";
        _sharepointConfigJson = "";
        _sharepointLists.Clear();
        _sharepointFields.Clear();
        _outlookCalendarName = "";
        _outlookConfigJson = "";
        _outlookCalendars.Clear();
        LoadOutlookConfig(null);
        _isEditingConnector = true;
        ClearBanners();
    }

    private void SelectConnector(ConnectorDto connector)
    {
        _selectedConnector = connector;
        _connName = connector.Name;
        _connType = connector.Type;
        _isEditingConnector = false;

        if (connector.Sql != null)
        {
            _sqlHost = connector.Sql.Host;
            _sqlPort = connector.Sql.Port;
            _sqlDatabase = connector.Sql.Database;
            _sqlUsername = connector.Sql.Username;
            _sqlTrustCert = connector.Sql.TrustServerCertificate;
        }
        else if (connector.Csv != null)
        {
            _csvPath = connector.Csv.Path;
            _csvDelimiter = connector.Csv.Delimiter;
        }
        else if (connector.Path != null)
        {
            _localPath = connector.Path.Path;
        }
        else if (connector.Sftp != null)
        {
            _sftpHost = connector.Sftp.Host;
            _sftpPort = connector.Sftp.Port;
            _sftpUsername = connector.Sftp.Username;
            _sftpRemotePath = connector.Sftp.RemotePath;
            _sftpPassword = "";
        }
        else if (connector.SharePoint != null)
        {
            _sharepointSiteUrl = connector.SharePoint.SiteUrl;
            _sharepointListName = connector.SharePoint.ListName;
            _sharepointConfigJson = connector.SharePoint.ConfigJson ?? "";
            _sharepointLists.Clear();
            _sharepointFields.Clear();
            _ = LoadSharePointFieldsAsync();
        }
        else if (connector.OutlookCalendar != null)
        {
            _outlookCalendarName = connector.OutlookCalendar.CalendarName;
            _outlookConfigJson = connector.OutlookCalendar.ConfigJson ?? "";
            _outlookCalendars.Clear();
            LoadOutlookConfig(_outlookConfigJson);
        }
 
        ClearBanners();
    }

    private async Task TestConnectionAsync()
    {
        ClearBanners();
        _isBusy = true;
        try
        {
            var req = CreateTestConnectorRequest();
            var response = await ConnectorApiClient.TestAsync(req, CancellationToken.None);
            if (response != null && response.IsSuccess)
            {
                _successMessage = "Connection test succeeded!";
            }
            else
            {
                _errorMessage = $"Connection test failed: {response?.Message ?? "No details available."}";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Connection test error: {ex.Message}";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task SaveConnectorAsync()
    {
        if (string.IsNullOrWhiteSpace(_connName))
        {
            _errorMessage = "Connector name is required.";
            return;
        }

        ClearBanners();
        _isBusy = true;
        try
        {
            if (_connType == ConnectorType.OutlookCalendar)
            {
                UpdateOutlookConfigJson();
            }

            var req = new CreateConnectorRequest(
                _connName,
                _connType,
                (_connType == ConnectorType.SqlServer || _connType == ConnectorType.Postgres)
                    ? new SqlConnectorSettingsInputDto(_sqlHost, _sqlPort, _sqlDatabase, _sqlUsername, _sqlPassword, _sqlTrustCert, null)
                    : null,
                _connType == ConnectorType.Csv ? new CsvConnectorSettingsDto(_csvPath, _csvDelimiter) : null,
                null,
                _connType == ConnectorType.Path ? new PathConnectorSettingsDto(_localPath) : null,
                _connType == ConnectorType.Sftp ? new SftpConnectorSettingsInputDto(_sftpHost, _sftpPort, _sftpUsername, _sftpPassword, _sftpRemotePath) : null,
                _connType == ConnectorType.SharePoint ? new SharePointConnectorSettingsInputDto(_sharepointSiteUrl, _sharepointListName, null) : null,
                _connType == ConnectorType.OutlookCalendar ? new OutlookCalendarConnectorSettingsInputDto(_outlookCalendarName, _outlookConfigJson) : null
            );

            var result = await ConnectorApiClient.CreateAsync(req, CancellationToken.None);
            if (result != null)
            {
                _successMessage = $"Connector '{result.Name}' created successfully.";
                _isEditingConnector = false;
                await LoadListsAsync();
                _selectedConnector = _connectors.FirstOrDefault(c => c.Id == result.Id);
            }
            else
            {
                _errorMessage = "Failed to save connector.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Save error: {ex.Message}";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private TestConnectorRequest CreateTestConnectorRequest()
    {
        if (_connType == ConnectorType.OutlookCalendar)
        {
            UpdateOutlookConfigJson();
        }

        return new TestConnectorRequest(
            _connType,
            (_connType == ConnectorType.SqlServer || _connType == ConnectorType.Postgres)
                ? new SqlConnectorSettingsInputDto(_sqlHost, _sqlPort, _sqlDatabase, _sqlUsername, _sqlPassword, _sqlTrustCert, null)
                : null,
            _connType == ConnectorType.Csv ? new CsvConnectorSettingsDto(_csvPath, _csvDelimiter) : null,
            null,
            _connType == ConnectorType.Path ? new PathConnectorSettingsDto(_localPath) : null,
            _connType == ConnectorType.Sftp ? new SftpConnectorSettingsInputDto(_sftpHost, _sftpPort, _sftpUsername, _sftpPassword, _sftpRemotePath) : null,
            _connType == ConnectorType.SharePoint ? new SharePointConnectorSettingsInputDto(_sharepointSiteUrl, _sharepointListName, null) : null,
            _connType == ConnectorType.OutlookCalendar ? new OutlookCalendarConnectorSettingsInputDto(_outlookCalendarName, _outlookConfigJson) : null
        );
    }

    // Job Methods
    private void PrepareNewJob()
    {
        _selectedJob = null;
        _jobName = "";
        _jobCron = "*/15 * * * *";
        _jobEnabled = true;
        _jobSourceId = "";
        _jobDestinationId = "";
        _selectedGroupIds = new List<Guid>();
        _owners = [];
        _guests = [];
        _isEditingJob = true;
        _jobPassword = "";
        ClearBanners();
    }

    private async Task SelectJob(IntegrationJobDto job)
    {
        _selectedJob = job;
        _jobName = job.Name;
        _jobCron = job.CronExpression ?? "";
        _jobEnabled = job.IsEnabled;
        _selectedGroupIds = job.GroupIds?.ToList() ?? new List<Guid>();
        _isEditingJob = false;
        _runs = [];
        _owners = [];
        _guests = [];
        _jobSubTab = "details";
        ClearBanners();

        if (job.IsUnlocked)
        {
            try
            {
                _runs = await JobsApiClient.GetRunsAsync(job.Id, CancellationToken.None);
                _owners = await JobsApiClient.GetOwnersAsync(job.Id, CancellationToken.None);
                _guests = await JobsApiClient.GetGuestsAsync(job.Id, CancellationToken.None);
            }
            catch (Exception ex)
            {
                _errorMessage = $"Failed to load job details: {ex.Message}";
            }
        }
    }

    private bool CanManageAccess()
    {
        if (AppState.IsAdmin) return true;
        return _owners.Any(o => o.Username == AppState.CurrentUsername);
    }

    private async Task AddOwnerAsync()
    {
        if (string.IsNullOrWhiteSpace(_newOwnerUsername) || _selectedJob == null) return;
        ClearBanners();
        _isBusy = true;
        try
        {
            var success = await JobsApiClient.AddOwnerAsync(_selectedJob.Id, new AddOwnerRequest(_newOwnerUsername), CancellationToken.None);
            if (success)
            {
                _successMessage = $"Successfully added '{_newOwnerUsername}' as owner.";
                _newOwnerUsername = "";
                _owners = await JobsApiClient.GetOwnersAsync(_selectedJob.Id, CancellationToken.None);
            }
            else
            {
                _errorMessage = "Failed to add owner. Verify the user exists and you have owner permissions.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error adding owner: {ex.Message}";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task RemoveOwnerAsync(Guid ownerUserId)
    {
        if (_selectedJob == null) return;
        ClearBanners();
        _isBusy = true;
        try
        {
            var success = await JobsApiClient.RemoveOwnerAsync(_selectedJob.Id, ownerUserId, CancellationToken.None);
            if (success)
            {
                _successMessage = "Owner removed successfully.";
                _owners = await JobsApiClient.GetOwnersAsync(_selectedJob.Id, CancellationToken.None);
            }
            else
            {
                _errorMessage = "Failed to remove owner.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error removing owner: {ex.Message}";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private bool IsCreator()
    {
        return _owners.Any(o => o.IsCreator && o.Username == AppState.CurrentUsername);
    }

    private async Task HandleUnlockKeyup(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await UnlockJobAsync();
        }
    }

    private async Task UnlockJobAsync()
    {
        if (_selectedJob == null || string.IsNullOrEmpty(_unlockPassword)) return;
        ClearBanners();
        _isBusy = true;
        try
        {
            var success = await JobsApiClient.UnlockAsync(_selectedJob.Id, _unlockPassword, CancellationToken.None);
            if (success)
            {
                _successMessage = "Job unlocked successfully.";
                _unlockPassword = "";
                await LoadListsAsync();
                var updatedJob = _jobs.FirstOrDefault(j => j.Id == _selectedJob.Id);
                if (updatedJob != null)
                {
                    await SelectJob(updatedJob);
                }
            }
            else
            {
                _errorMessage = "Incorrect password.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unlock error: {ex.Message}";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task UpdatePasswordAsync()
    {
        if (_selectedJob == null) return;
        ClearBanners();
        _isBusy = true;
        try
        {
            var passwordValue = string.IsNullOrWhiteSpace(_changePasswordInput) ? null : _changePasswordInput;
            var success = await JobsApiClient.UpdatePasswordAsync(_selectedJob.Id, passwordValue, CancellationToken.None);
            if (success)
            {
                _successMessage = passwordValue == null ? "Password removed and permissions reset." : "Password updated and permissions reset.";
                _changePasswordInput = "";
                await LoadListsAsync();
                var updatedJob = _jobs.FirstOrDefault(j => j.Id == _selectedJob.Id);
                if (updatedJob != null)
                {
                    await SelectJob(updatedJob);
                }
            }
            else
            {
                _errorMessage = "Failed to update password. Only the job creator can set or change the password.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Password update error: {ex.Message}";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task InviteGuestAsync()
    {
        if (string.IsNullOrWhiteSpace(_newGuestUsername) || _selectedJob == null) return;
        ClearBanners();
        _isBusy = true;
        try
        {
            var success = await JobsApiClient.InviteGuestAsync(
                _selectedJob.Id, 
                new InviteGuestRequest(_newGuestUsername, _newGuestCanRead, _newGuestCanEdit, _newGuestCanCreateConnectors), 
                CancellationToken.None);
            if (success)
            {
                _successMessage = $"Successfully invited guest '{_newGuestUsername}'.";
                _newGuestUsername = "";
                _newGuestCanRead = true;
                _newGuestCanEdit = false;
                _newGuestCanCreateConnectors = false;
                _guests = await JobsApiClient.GetGuestsAsync(_selectedJob.Id, CancellationToken.None);
            }
            else
            {
