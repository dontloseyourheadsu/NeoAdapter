<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:NeoAdapter.Frontend.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="NeoAdapter.Frontend.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <!-- This only sets the DataContext for the previewer in an IDE,
    to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
    <vm:MainViewModel />
  </Design.DataContext>

  <UserControl.Styles>
    <Style Selector="Border.panel">
      <Setter Property="Background" Value="#141220" />
      <Setter Property="BorderBrush" Value="#2A2440" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
    </Style>
    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="#9B93B8" />
    </Style>
  </UserControl.Styles>

  <Grid Background="#0A0910" RowDefinitions="Auto,*" ColumnDefinitions="220,*">
    <Border Grid.RowSpan="2" Background="#100F1A" BorderBrush="#2A2440" BorderThickness="0,0,1,0">
      <StackPanel Margin="18,18,18,18" Spacing="10">
        <Border Background="#1A1828" CornerRadius="10" Padding="12" BorderBrush="#3D365D" BorderThickness="1">
          <StackPanel>
            <TextBlock Text="NeoAdapter" FontSize="22" FontWeight="Bold" Foreground="#E8E3F5"/>
            <TextBlock Text="Job Orchestrator" FontSize="11" Classes="muted"/>
          </StackPanel>
        </Border>

        <TextBlock Text="NAVIGATION" FontSize="10" Classes="muted" Margin="4,10,0,0"/>
        <Border Background="#2A2243" CornerRadius="8" Padding="10" BorderBrush="#4C3B79" BorderThickness="1">
          <TextBlock Text="Dashboard" Foreground="#C7A6FF" FontWeight="SemiBold"/>
        </Border>
      </StackPanel>
    </Border>

    <Border Grid.Column="1" Background="#100F1A" BorderBrush="#2A2440" BorderThickness="0,0,0,1" Padding="20,14">
      <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
        <StackPanel Orientation="Vertical">
          <TextBlock Text="Dashboard" FontSize="20" FontWeight="Bold" Foreground="#E8E3F5"/>
          <TextBlock Text="NeoAdapter / Overview" Classes="muted" FontSize="11"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <TextBlock Text="Updated:" Classes="muted" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding LastUpdated}" Foreground="#C7A6FF" VerticalAlignment="Center" FontWeight="SemiBold"/>
          <Button Content="Refresh" Command="{Binding RefreshCommand}" />
        </StackPanel>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1" Grid.Column="1" HorizontalScrollBarVisibility="Disabled">
      <StackPanel Margin="20" Spacing="16">
        <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF5F7E"/>

        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
          <Border Classes="panel" Padding="14">
            <StackPanel>
              <TextBlock Text="TOTAL JOBS" FontSize="11" Classes="muted"/>
              <TextBlock Text="{Binding TotalJobs}" FontSize="30" FontWeight="Bold" Foreground="#E8E3F5"/>
            </StackPanel>
          </Border>
          <Border Grid.Column="1" Classes="panel" Padding="14">
            <StackPanel>
              <TextBlock Text="ACTIVE JOBS" FontSize="11" Classes="muted"/>
              <TextBlock Text="{Binding ActiveJobs}" FontSize="30" FontWeight="Bold" Foreground="#E8E3F5"/>
            </StackPanel>
          </Border>
          <Border Grid.Column="2" Classes="panel" Padding="14">
            <StackPanel>
              <TextBlock Text="QUEUED JOBS" FontSize="11" Classes="muted"/>
              <TextBlock Text="{Binding QueuedJobs}" FontSize="30" FontWeight="Bold" Foreground="#E8E3F5"/>
            </StackPanel>
          </Border>
          <Border Grid.Column="3" Classes="panel" Padding="14">
            <StackPanel>
              <TextBlock Text="FAILED (24H)" FontSize="11" Classes="muted"/>
              <TextBlock Text="{Binding FailedJobs}" FontSize="30" FontWeight="Bold" Foreground="#E8E3F5"/>
            </StackPanel>
          </Border>
        </Grid>

        <Grid ColumnDefinitions="2*,*" ColumnSpacing="12">
          <Border Classes="panel" Padding="14">
            <StackPanel Spacing="10">
              <TextBlock Text="Today's Schedule" FontSize="15" FontWeight="SemiBold" Foreground="#E8E3F5"/>
              <ItemsControl ItemsSource="{Binding Schedule}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid ColumnDefinitions="70,*" Margin="0,4,0,4">
                      <TextBlock Text="{Binding TimeLabel}" Classes="muted" VerticalAlignment="Center"/>
                      <Border Grid.Column="1" Background="#1A1828" CornerRadius="8" Padding="8" BorderBrush="#2A2440" BorderThickness="1">
                        <Grid ColumnDefinitions="6,*,Auto" ColumnSpacing="8">
                          <Border Background="{Binding ColorHex}" CornerRadius="3"/>
                          <TextBlock Grid.Column="1" Text="{Binding JobName}" Foreground="#E8E3F5" VerticalAlignment="Center"/>
                          <TextBlock Grid.Column="2" Text="{Binding DurationLabel}" Foreground="{Binding ColorHex}" VerticalAlignment="Center"/>
                        </Grid>
                      </Border>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <Border Grid.Column="1" Classes="panel" Padding="14">
            <StackPanel Spacing="10">
              <TextBlock Text="Active Jobs" FontSize="15" FontWeight="SemiBold" Foreground="#E8E3F5"/>
              <ItemsControl ItemsSource="{Binding ActiveJobsList}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="#1A1828" CornerRadius="8" BorderBrush="#2A2440" BorderThickness="1" Padding="10" Margin="0,2,0,2">
                      <Grid ColumnDefinitions="10,*,Auto" ColumnSpacing="10">
                        <Ellipse Fill="{Binding ColorHex}" Width="10" Height="10" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1">
                          <TextBlock Text="{Binding Name}" Foreground="#E8E3F5" FontWeight="SemiBold"/>
                          <TextBlock Text="{Binding Meta}" Classes="muted" FontSize="11"/>
                        </StackPanel>
                        <Border Grid.Column="2" Background="#201E30" CornerRadius="12" Padding="8,2" VerticalAlignment="Center">
                          <TextBlock Text="{Binding Status}" Foreground="{Binding ColorHex}" FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
        </Grid>

        <Border Classes="panel" Padding="14">
          <StackPanel Spacing="10">
            <TextBlock Text="Connected Integrations" FontSize="15" FontWeight="SemiBold" Foreground="#E8E3F5"/>
            <ItemsControl ItemsSource="{Binding Integrations}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" ItemWidth="180"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="#1A1828" CornerRadius="10" BorderBrush="#2A2440" BorderThickness="1" Padding="12" Margin="0,0,8,8">
                    <StackPanel>
                      <TextBlock Text="{Binding Name}" Foreground="{Binding ColorHex}" FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding JobCount, StringFormat='{}{0} jobs'}" Classes="muted" FontSize="11"/>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <Border Classes="panel" Padding="14">
          <StackPanel Spacing="10">
            <TextBlock Text="Live Log Stream" FontSize="15" FontWeight="SemiBold" Foreground="#E8E3F5"/>
            <ItemsControl ItemsSource="{Binding Logs}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="110,56,*" ColumnSpacing="8" Margin="0,2,0,2">
                    <TextBlock Text="{Binding TimestampUtc.LocalDateTime, StringFormat='{}{0:HH:mm:ss}'}" Classes="muted" FontFamily="Consolas"/>
                    <TextBlock Grid.Column="1" Text="{Binding Level}" Foreground="#C7A6FF" FontFamily="Consolas"/>
                    <TextBlock Grid.Column="2" Text="{Binding Message}" Foreground="#C9C4D9"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
