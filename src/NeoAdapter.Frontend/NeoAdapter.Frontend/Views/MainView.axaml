<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="using:NeoAdapter.Frontend.Views"
             xmlns:vm="using:NeoAdapter.Frontend.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="1200"
             d:DesignHeight="860"
             x:Class="NeoAdapter.Frontend.Views.MainView"
             x:DataType="vm:MainViewModel">
    <Grid Background="{DynamicResource NeoBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border IsVisible="{Binding IsAuthenticated}" Background="{DynamicResource NeoHeaderBrush}" BorderBrush="{DynamicResource NeoBorderBrush}" BorderThickness="0,0,0,1" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="NeoAdapter" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource NeoPrimaryTextBrush}" />
                    <TextBlock Text="Connectors, integration jobs, and live runs" Classes="muted" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="User:" Classes="muted" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding CurrentUsername}" Foreground="{DynamicResource NeoPrimaryTextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Text="Updated:" Classes="muted" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding LastUpdated}" Foreground="{DynamicResource NeoPrimaryTextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button Content="Refresh" Command="{Binding RefreshCommand}" Classes="ghost-btn" />
                    <Button Content="Logout" Command="{Binding LogoutCommand}" Classes="ghost-btn" />
                </StackPanel>
            </Grid>
        </Border>

        <Border IsVisible="{Binding IsNotAuthenticated}" Grid.RowSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center" Width="420" Classes="panel" Padding="22">
            <StackPanel Spacing="12">
                <TextBlock Text="Sign In" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource NeoPrimaryTextBrush}" />
                <TextBlock Text="Use username and password to access NeoAdapter." Classes="muted"/>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource NeoDangerBrush}" />

                <TextBox Watermark="Username" Text="{Binding LoginUsername}" Classes="input" />
                <TextBox Watermark="Password" PasswordChar="*" Text="{Binding LoginPassword}" Classes="input" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Content="Login" Command="{Binding LoginCommand}" Classes="primary-btn" />
                    <Button Grid.Column="1" Content="Register" Command="{Binding RegisterCommand}" Classes="ghost-btn" />
                </Grid>
            </StackPanel>
        </Border>

        <TabControl IsVisible="{Binding IsAuthenticated}" Grid.Row="1" Margin="16" SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="Dashboard">
                <views:DashboardView DataContext="{Binding}" />
            </TabItem>
            <TabItem Header="Connectors and Jobs">
                <views:IntegrationsView DataContext="{Binding}" />
            </TabItem>
        </TabControl>

        <!-- keeps design-time layout stable when authenticated header is hidden -->
        <Border IsVisible="False" Background="{DynamicResource NeoHeaderBrush}" BorderBrush="{DynamicResource NeoBorderBrush}" BorderThickness="0,0,0,1" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="NeoAdapter" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource NeoPrimaryTextBrush}" />
                    <TextBlock Text="Connectors, integration jobs, and live runs" Classes="muted" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
