<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:NeoAdapter.Frontend.ViewModels"
             xmlns:jobs="using:NeoAdapter.Contracts.IntegrationJobs"
             xmlns:connectors="using:NeoAdapter.Contracts.Connectors"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="NeoAdapter.Frontend.Views.IntegrationsView"
             x:DataType="vm:MainViewModel"
             Name="IntegrationsRoot">
    <TabControl Margin="0" Padding="0">
        <!-- Tab 1: Integration Workflows -->
        <TabItem Header="Integration Workflows" Padding="12,6">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="18" Margin="0,12,0,24">
                    <TextBlock Text="Job Builder" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource NeoPrimaryTextBrush}" />
                    <TextBlock Text="Design multi-step data integration workflows." Classes="muted" />

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource NeoDangerBrush}" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource NeoAccentBrush}" />

                    <Grid ColumnDefinitions="*,2*" ColumnSpacing="18">
                        <!-- Job List -->
                        <Border Classes="panel" Padding="14">
                            <StackPanel Spacing="12">
                                <TextBlock Text="My Integration Jobs" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource NeoPrimaryTextBrush}" />
                                
                                <ItemsControl ItemsSource="{Binding IntegrationJobs}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="jobs:IntegrationJobDto">
                                            <Border Classes="list-row" Margin="0,0,0,8">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource NeoPrimaryTextBrush}" />
                                                        <TextBlock Text="{Binding Steps.Count, StringFormat='\{0\} Steps'}" Classes="muted" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                                        <Button Content="Run" 
                                                                Classes="ghost-btn" 
                                                                Command="{Binding #IntegrationsRoot.DataContext.RunIntegrationJobCommand}"
                                                                CommandParameter="{Binding}" />
                                                        <Button Content="Logs" 
                                                                Classes="ghost-btn" 
                                                                Command="{Binding #IntegrationsRoot.DataContext.ViewJobLogsCommand}"
                                                                CommandParameter="{Binding}" />
                                                        <Button Content="Edit" Classes="ghost-btn" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button Content="+ Create New Job" Command="{Binding CreateIntegrationJobCommand}" Classes="primary-btn" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- Step Configuration -->
                        <Border Grid.Column="1" Classes="panel" Padding="14">
                            <StackPanel Spacing="18">
                                <TextBlock Text="Job Details &amp; Steps" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource NeoPrimaryTextBrush}" />
                                
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Integration Name" Classes="muted" FontSize="12" />
                                    <TextBox Watermark="e.g. Daily Inventory Sync" Text="{Binding NewIntegrationJobName}" Classes="input" />
                                </StackPanel>
                                
                                <Border BorderBrush="{DynamicResource NeoBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="Step 1: Data Transfer" FontWeight="SemiBold" Foreground="{DynamicResource NeoAccentBrush}" />
                                        
                                        <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="12">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Source Connector" Classes="muted" FontSize="12" />
                                                <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding Connectors}" SelectedItem="{Binding SelectedSourceConnector}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="connectors:ConnectorDto">
                                                            <TextBlock Text="{Binding Name}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>

                                            <TextBlock Grid.Column="1" Text="→" VerticalAlignment="Center" FontSize="20" Margin="0,14,0,0" Foreground="{DynamicResource NeoAccentBrush}" />

                                            <StackPanel Grid.Column="2" Spacing="4">
                                                <TextBlock Text="Destination Connector" Classes="muted" FontSize="12" />
                                                <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding Connectors}" SelectedItem="{Binding SelectedDestinationConnector}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="connectors:ConnectorDto">
                                                            <TextBlock Text="{Binding Name}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <StackPanel Spacing="8">
                                    <CheckBox Content="Enable background scheduling" IsChecked="{Binding NewIntegrationJobEnabled}" />
                                    <TextBox Watermark="Cron Expression (optional, e.g. 0 0 * * *)" 
                                             Text="{Binding NewIntegrationJobCronExpression}" 
                                             IsEnabled="{Binding NewIntegrationJobEnabled}" 
                                             Classes="input" />
                                </StackPanel>
                                
                                <Border Background="{DynamicResource NeoBorderBrush}" Height="1" Margin="0,8" />
                                
                                <TextBlock Text="Note: Connectors are now managed within the job context. Use existing ones or wait for the next update to create them inline." 
                                           Classes="muted" 
                                           TextWrapping="Wrap" 
                                           FontSize="12" 
                                           FontStyle="Italic" />

                                <Button Content="Save Integration Job" 
                                        Command="{Binding CreateIntegrationJobCommand}" 
                                        Classes="primary-btn" 
                                        HorizontalAlignment="Right" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- Tab 2: Connectors Manager -->
        <TabItem Header="Connectors Manager" Padding="12,6">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="18" Margin="0,12,0,24">
                    <TextBlock Text="Connectors Manager" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource NeoPrimaryTextBrush}" />
                    <TextBlock Text="Configure source and destination connection profiles." Classes="muted" />

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource NeoDangerBrush}" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource NeoAccentBrush}" />

                    <Grid ColumnDefinitions="*,2*" ColumnSpacing="18">
                        <!-- Connectors List -->
                        <Border Classes="panel" Padding="14">
                            <StackPanel Spacing="12">
                                <TextBlock Text="My Connection Profiles" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource NeoPrimaryTextBrush}" />
                                
                                <ItemsControl ItemsSource="{Binding Connectors}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="connectors:ConnectorDto">
                                            <Border Classes="list-row" Margin="0,0,0,8">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource NeoPrimaryTextBrush}" />
                                                        <TextBlock Text="{Binding Type}" Classes="muted" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="CONNECTED" Foreground="{DynamicResource NeoAccentBrush}" VerticalAlignment="Center" FontSize="11" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Connector Configuration Form -->
                        <Border Grid.Column="1" Classes="panel" Padding="14">
                            <StackPanel Spacing="18">
                                <TextBlock Text="Create New Connection Profile" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource NeoPrimaryTextBrush}" />
                                
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Profile Name" Classes="muted" FontSize="12" />
                                    <TextBox Watermark="e.g. Sales DB, Remote SFTP Server" Text="{Binding NewConnectorName}" Classes="input" />
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Connector Type" Classes="muted" FontSize="12" />
                                    <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding ConnectorTypes}" SelectedItem="{Binding NewConnectorType}" />
                                </StackPanel>

                                <!-- SqlServer / Postgres Configuration -->
                                <StackPanel Spacing="12" IsVisible="{Binding IsSqlConnectorSelected}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Host Address" Classes="muted" FontSize="12" />
                                        <TextBox Watermark="localhost or server IP" Text="{Binding SqlServer}" Classes="input" />
                                    </StackPanel>
                                    <Grid ColumnDefinitions="*,2*" ColumnSpacing="12">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Port" Classes="muted" FontSize="12" />
                                            <TextBox Text="{Binding SqlPort}" Classes="input" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Text="Database Name" Classes="muted" FontSize="12" />
                                            <TextBox Text="{Binding SqlDatabase}" Classes="input" />
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Username" Classes="muted" FontSize="12" />
                                        <TextBox Text="{Binding SqlUsername}" Classes="input" />
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Password" Classes="muted" FontSize="12" />
                                        <TextBox PasswordChar="*" Text="{Binding SqlPassword}" Classes="input" />
                                    </StackPanel>
                                    <CheckBox Content="Trust Server Certificate" IsChecked="{Binding SqlTrustServerCertificate}" />
                                </StackPanel>

                                <!-- CSV Configuration -->
                                <StackPanel Spacing="12" IsVisible="{Binding IsCsvConnectorSelected}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Local CSV File Path" Classes="muted" FontSize="12" />
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <TextBox Watermark="C:\path\to\data.csv" Text="{Binding CsvPath}" Classes="input" />
                                            <Button Grid.Column="1" Content="Browse..." Click="OnBrowseCsvClicked" Classes="ghost-btn" />
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Column Delimiter" Classes="muted" FontSize="12" />
                                        <TextBox Text="{Binding CsvDelimiter}" Classes="input" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- Excel Configuration -->
                                <StackPanel Spacing="12" IsVisible="{Binding IsExcelConnectorSelected}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Local Excel File Path" Classes="muted" FontSize="12" />
                                        <TextBox Watermark="C:\path\to\data.xlsx" Text="{Binding ExcelPath}" Classes="input" />
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Sheet Name (Optional)" Classes="muted" FontSize="12" />
                                        <TextBox Watermark="Sheet1" Text="{Binding ExcelSheetName}" Classes="input" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- Path Configuration -->
                                <StackPanel Spacing="12" IsVisible="{Binding IsPathConnectorSelected}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Local Directory/File Path" Classes="muted" FontSize="12" />
                                        <TextBox Watermark="e.g. C:\temp\sync_folder" Text="{Binding LocalPath}" Classes="input" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- SFTP Configuration -->
                                <StackPanel Spacing="12" IsVisible="{Binding IsSftpConnectorSelected}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="SFTP Host Address" Classes="muted" FontSize="12" />
                                        <TextBox Watermark="sftp.domain.com or IP" Text="{Binding SftpHost}" Classes="input" />
                                    </StackPanel>
                                    <Grid ColumnDefinitions="*,2*" ColumnSpacing="12">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="SFTP Port" Classes="muted" FontSize="12" />
                                            <TextBox Text="{Binding SftpPort}" Classes="input" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Text="SFTP Username" Classes="muted" FontSize="12" />
                                            <TextBox Text="{Binding SftpUsername}" Classes="input" />
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="SFTP Password" Classes="muted" FontSize="12" />
                                        <TextBox PasswordChar="*" Text="{Binding SftpPassword}" Classes="input" />
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="SFTP Remote Path" Classes="muted" FontSize="12" />
                                        <TextBox Watermark="e.g. /upload or /home/user/files" Text="{Binding SftpRemotePath}" Classes="input" />
                                    </StackPanel>
                                </StackPanel>

                                <Border Background="{DynamicResource NeoBorderBrush}" Height="1" Margin="0,8" />

                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <Button Grid.Column="0" Content="Test Connection" Command="{Binding TestConnectorCommand}" Classes="ghost-btn" />
                                    <Button Grid.Column="2" Content="Create Profile" Command="{Binding CreateConnectorCommand}" Classes="primary-btn" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</UserControl>
