<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:NeoAdapter.Frontend.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="1000"
             d:DesignHeight="700"
             x:Class="NeoAdapter.Frontend.Views.UserAdminView"
             x:DataType="vm:MainViewModel">
    <Grid ColumnDefinitions="3*,4*" ColumnSpacing="16">
        <!-- Left: Users List -->
        <Border Grid.Column="0" Classes="panel" Padding="16">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0" Text="Organization Users" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource NeoPrimaryTextBrush}" Margin="0,0,0,12"/>
                <ListBox Grid.Row="1" ItemsSource="{Binding OrgUsers}" SelectedItem="{Binding SelectedOrgUser}" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Classes="list-row" Padding="12,10" Margin="0,2">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Username}" Foreground="{DynamicResource NeoPrimaryTextBrush}" FontWeight="SemiBold" FontSize="14" />
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="Group:" Classes="muted"/>
                                            <TextBlock Text="{Binding GroupName, FallbackValue='None'}" Classes="muted" Foreground="{DynamicResource NeoAccentBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                        <Border Background="#1C2E2A" BorderBrush="#2D5A4E" BorderThickness="1" CornerRadius="4" Padding="6,2" IsVisible="{Binding RoleAdmin}">
                                            <TextBlock Text="Admin" Foreground="#52D1A3" FontSize="10" FontWeight="SemiBold"/>
                                        </Border>
                                        <Border Background="#251F40" BorderBrush="#4A398A" BorderThickness="1" CornerRadius="4" Padding="6,2" IsVisible="{Binding RoleCreate}">
                                            <TextBlock Text="Create" Foreground="#C7A6FF" FontSize="10" FontWeight="SemiBold"/>
                                        </Border>
                                        <Border Background="#2C2836" BorderBrush="#504C5A" BorderThickness="1" CornerRadius="4" Padding="6,2" IsVisible="{Binding RoleEdit}">
                                            <TextBlock Text="Edit" Foreground="#C4C1CC" FontSize="10" FontWeight="SemiBold"/>
                                        </Border>
                                        <Border Background="#1F2836" BorderBrush="#3B495C" BorderThickness="1" CornerRadius="4" Padding="6,2" IsVisible="{Binding RoleRead}">
                                            <TextBlock Text="Read" Foreground="#A6C5FF" FontSize="10" FontWeight="SemiBold"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Right: Details and Editing Panel -->
        <Border Grid.Column="1" Classes="panel" Padding="16" IsVisible="{Binding SelectedOrgUser, Converter={x:Static ObjectConverters.IsNotNull}}">
            <ScrollViewer>
                <StackPanel Spacing="16">
                    <TextBlock Text="Manage User Permissions" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource NeoPrimaryTextBrush}"/>
                    
                    <Border Background="{DynamicResource NeoPanelAltBrush}" CornerRadius="8" Padding="12">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Username" Classes="muted"/>
                            <TextBlock Text="{Binding SelectedOrgUser.Username}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource NeoPrimaryTextBrush}"/>
                            <TextBlock Text="User ID" Classes="muted" Margin="0,6,0,0"/>
                            <TextBlock Text="{Binding SelectedOrgUser.Id}" Classes="mono-muted"/>
                        </StackPanel>
                    </Border>

                    <!-- Group Assignment -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Group Membership" FontWeight="SemiBold" Foreground="{DynamicResource NeoPrimaryTextBrush}"/>
                        <ComboBox ItemsSource="{Binding OrgGroups}" SelectedItem="{Binding SelectedOrgUserGroup}" Classes="input" HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Content="Remove from Group" Command="{Binding ClearGroupCommand}" Classes="ghost-btn" HorizontalAlignment="Right" Margin="0,4,0,0" IsVisible="{Binding SelectedOrgUserGroup, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    </StackPanel>

                    <!-- Permissions/Roles Checkboxes -->
                    <StackPanel Spacing="12">
                        <TextBlock Text="Roles &amp; Permissions" FontWeight="SemiBold" Foreground="{DynamicResource NeoPrimaryTextBrush}"/>
                        
                        <CheckBox IsChecked="{Binding EditUserRoleRead}" VerticalContentAlignment="Center">
                            <StackPanel>
                                <TextBlock Text="Read (View-Only)" Foreground="{DynamicResource NeoPrimaryTextBrush}" FontWeight="SemiBold"/>
                                <TextBlock Text="Allows viewing connectors, integration jobs, execution history, and logs." Classes="muted"/>
                            </StackPanel>
                        </CheckBox>

                        <CheckBox IsChecked="{Binding EditUserRoleEdit}" VerticalContentAlignment="Center">
                            <StackPanel>
                                <TextBlock Text="Edit (Write)" Foreground="{DynamicResource NeoPrimaryTextBrush}" FontWeight="SemiBold"/>
                                <TextBlock Text="Allows editing and running existing jobs/connectors. Requires Read permission." Classes="muted"/>
                            </StackPanel>
                        </CheckBox>

                        <CheckBox IsChecked="{Binding EditUserRoleCreate}" VerticalContentAlignment="Center">
                            <StackPanel>
                                <TextBlock Text="Create" Foreground="{DynamicResource NeoPrimaryTextBrush}" FontWeight="SemiBold"/>
                                <TextBlock Text="Allows creating new connectors and jobs. Requires Edit permission." Classes="muted"/>
                            </StackPanel>
                        </CheckBox>

                        <CheckBox IsChecked="{Binding EditUserRoleAdmin}" VerticalContentAlignment="Center">
                            <StackPanel>
                                <TextBlock Text="Organization Administrator" Foreground="{DynamicResource NeoDangerBrush}" FontWeight="Bold"/>
                                <TextBlock Text="Bypasses all group checks. Full read, write, and create permissions across the entire organization." Classes="muted"/>
                            </StackPanel>
                        </CheckBox>
                    </StackPanel>

                    <!-- Save & Messages -->
                    <StackPanel Spacing="8" Margin="0,12,0,0">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource NeoDangerBrush}" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#52D1A3" TextWrapping="Wrap" />
                        <Button Content="Save Changes" Command="{Binding SaveUserRolesCommand}" Classes="primary-btn" HorizontalAlignment="Stretch" Padding="0,12"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
