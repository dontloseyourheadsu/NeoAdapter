<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:NeoAdapter.Frontend.ViewModels"
             xmlns:jobs="using:NeoAdapter.Contracts.IntegrationJobs"
             xmlns:converters="using:NeoAdapter.Frontend.Converters"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="NeoAdapter.Frontend.Views.LogsView"
             x:DataType="vm:MainViewModel">
    
    <UserControl.Resources>
        <converters:LogLevelColorConverter x:Key="LogLevelColorConverter"/>
        <converters:RunStatusColorConverter x:Key="RunStatusColorConverter"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*" Margin="16">
        <!-- Header / Selector Panel -->
        <Border Classes="panel" Padding="14" Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="12">
                <!-- Job Selector -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Select Integration Job" Classes="muted" FontSize="12" />
                    <ComboBox HorizontalAlignment="Stretch" 
                              ItemsSource="{Binding IntegrationJobs}" 
                              SelectedItem="{Binding SelectedLogJob}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="jobs:IntegrationJobDto">
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Run Selector -->
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="Execution Run" Classes="muted" FontSize="12" />
                    <ComboBox HorizontalAlignment="Stretch" 
                              ItemsSource="{Binding LogRuns}" 
                              SelectedItem="{Binding SelectedLogRun}"
                              IsEnabled="{Binding LogRuns.Count}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="jobs:IntegrationJobRunDto">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding StartedAtUtc.LocalDateTime, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" />
                                    <TextBlock Text="|" Foreground="{DynamicResource NeoMutedTextBrush}" />
                                    <TextBlock Text="{Binding Status}" Foreground="{Binding Status, Converter={StaticResource RunStatusColorConverter}}" FontWeight="Bold" />
                                    <TextBlock Text="|" Foreground="{DynamicResource NeoMutedTextBrush}" />
                                    <TextBlock Text="{Binding StartedBy, StringFormat='By: \{0\}'}" Classes="muted" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Refresh Button -->
                <Button Grid.Column="2" 
                        Content="Refresh Logs" 
                        Command="{Binding RefreshCommand}" 
                        Classes="ghost-btn" 
                        VerticalAlignment="Bottom" 
                        Height="32" 
                        Margin="0,0,0,2" />
            </Grid>
        </Border>

        <!-- Run Metadata Summary Panel -->
        <Border Grid.Row="1" 
                Classes="panel" 
                Padding="12" 
                Margin="0,0,0,12" 
                IsVisible="{Binding SelectedLogRun, Converter={x:Static ObjectConverters.IsNotNull}}">
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
                <StackPanel>
                    <TextBlock Text="STATUS" Classes="muted" FontSize="10" />
                    <TextBlock Text="{Binding SelectedLogRun.Status}" 
                               Foreground="{Binding SelectedLogRun.Status, Converter={StaticResource RunStatusColorConverter}}" 
                               FontWeight="Bold" 
                               FontSize="14" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="TRIGGERED BY" Classes="muted" FontSize="10" />
                    <TextBlock Text="{Binding SelectedLogRun.StartedBy}" 
                               Foreground="{DynamicResource NeoPrimaryTextBrush}" 
                               FontWeight="SemiBold" 
                               FontSize="14" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="RECORDS PROCESSED" Classes="muted" FontSize="10" />
                    <TextBlock Text="{Binding SelectedLogRun.RecordsProcessed}" 
                               Foreground="{DynamicResource NeoAccentBrush}" 
                               FontWeight="Bold" 
                               FontSize="14" />
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Text="STARTED AT" Classes="muted" FontSize="10" />
                    <TextBlock Text="{Binding SelectedLogRun.StartedAtUtc.LocalDateTime, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" 
                               Foreground="{DynamicResource NeoPrimaryTextBrush}" 
                               FontWeight="SemiBold" 
                               FontSize="14" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Terminal log output -->
        <Border Grid.Row="2" CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource NeoBorderBrush}" Background="#050408" Padding="14">
            <DockPanel>
                <!-- Loading indicator -->
                <TextBlock DockPanel.Dock="Top" 
                           Text="Loading logs..." 
                           Foreground="{DynamicResource NeoAccentBrush}" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,8" 
                           IsVisible="{Binding LogIsLoading}" />

                <!-- No Logs Message -->
                <TextBlock Text="No execution logs found for this job/run." 
                           Foreground="{DynamicResource NeoMutedTextBrush}" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center" 
                           IsVisible="{Binding !LogEntries.Count}" />

                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" IsVisible="{Binding LogEntries.Count}">
                    <StackPanel Spacing="4">
                        <ItemsControl ItemsSource="{Binding LogEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="jobs:JobLogDto">
                                    <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="10" Margin="0,1">
                                        <!-- Timestamp -->
                                        <TextBlock Text="{Binding TimestampUtc.LocalDateTime, StringFormat='{}{0:HH:mm:ss.fff}'}" 
                                                   Foreground="#7E769B" 
                                                   FontFamily="Consolas,Courier New,monospace" 
                                                   FontSize="12" />
                                        
                                        <!-- Level -->
                                        <TextBlock Grid.Column="1" 
                                                   Text="{Binding LogLevel, StringFormat='[{0}]'}" 
                                                   Foreground="{Binding LogLevel, Converter={StaticResource LogLevelColorConverter}}" 
                                                   FontWeight="Bold" 
                                                   FontFamily="Consolas,Courier New,monospace" 
                                                   FontSize="12" 
                                                   Width="55" />

                                        <!-- Message -->
                                        <TextBlock Grid.Column="2" 
                                                   Text="{Binding Message}" 
                                                   Foreground="{DynamicResource NeoPrimaryTextBrush}" 
                                                   FontFamily="Consolas,Courier New,monospace" 
                                                   FontSize="12" 
                                                   TextWrapping="Wrap" />

                                        <!-- Optional Details / Exception Stack -->
                                        <TextBlock Grid.Column="3" 
                                                   Text="{Binding Details}" 
                                                   Foreground="{DynamicResource NeoDangerBrush}" 
                                                   FontFamily="Consolas,Courier New,monospace" 
                                                   FontSize="10" 
                                                   IsVisible="{Binding Details, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" 
                                                   TextWrapping="Wrap" 
                                                   MaxWidth="300" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Load More Button -->
                        <Button Content="Load Older Logs" 
                                Command="{Binding LoadMoreLogsCommand}" 
                                IsVisible="{Binding LogHasMore}" 
                                Classes="ghost-btn" 
                                HorizontalAlignment="Center" 
                                Margin="0,12,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
